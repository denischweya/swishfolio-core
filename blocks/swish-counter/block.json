{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "swishfolio-core/swish-counter",
	"version": "1.0.0",
	"title": "Swish Counter",
	"category": "swishfolio",
	"description": "Row of animated stat counters. Each counter tweens from 0 to its target on first viewport entry.",
	"keywords": [ "counter", "stats", "metrics", "numbers" ],
	"textdomain": "swishfolio-core",
	"attributes": {
		"columns": {
			"type": "number",
			"default": 4
		},
		"align": {
			"type": "string",
			"default": "center"
		},
		"counterFontSize": {
			"type": "string",
			"default": ""
		},
		"counterFontWeight": {
			"type": "number",
			"default": 800
		},
		"counterColor": {
			"type": "string",
			"default": ""
		},
		"titleFontSize": {
			"type": "string",
			"default": ""
		},
		"titleColor": {
			"type": "string",
			"default": ""
		},
		"counterTitleGap": {
			"type": "number",
			"default": 8
		}
	},
	"supports": {
		"align": [ "wide", "full" ],
		"html": false,
		"spacing": {
			"margin": true,
			"padding": true
		}
	},
	"editorScript": "file:./build/index.js",
	"editorStyle": "file:./build/index.css",
	"style": "file:./build/style-index.css",
	"viewScript": "file:./build/view.js"
}
