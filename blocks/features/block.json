{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "swishfolio-core/features",
	"version": "2.0.0",
	"title": "Features",
	"category": "swishfolio",
	"description": "A bento-grid features section. Each card is a child Feature Card block; the parent holds global styles inherited by its cards.",
	"keywords": [ "features", "bento", "grid", "cards", "modules" ],
	"textdomain": "swishfolio-core",
	"attributes": {
		"gridGap": { "type": "string", "default": "2rem" },
		"cardBorderStyle": { "type": "string", "default": "solid" },
		"cardBorderColor": { "type": "string", "default": "" },
		"cardShadowColor": { "type": "string", "default": "" },
		"titleFontSize": { "type": "string", "default": "" },
		"subheadingFontSize": { "type": "string", "default": "" },
		"titleColor": { "type": "string", "default": "" },
		"iconColor": { "type": "string", "default": "" },
		"iconBackgroundColor": { "type": "string", "default": "" },
		"ctaTextColor": { "type": "string", "default": "" },
		"ctaBackgroundColor": { "type": "string", "default": "" },
		"cardBackgroundColor": { "type": "string", "default": "" },
		"cardAccentColor": { "type": "string", "default": "" }
	},
	"supports": {
		"align": [ "wide", "full" ],
		"html": false,
		"color": {
			"background": true,
			"text": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true
		}
	},
	"editorScript": "file:./build/index.js",
	"editorStyle": "file:./build/index.css",
	"style": "file:./build/style-index.css"
}
