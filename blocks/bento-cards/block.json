{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "swishfolio-core/bento-cards",
	"version": "1.0.0",
	"title": "Bento Cards",
	"category": "swishfolio",
	"description": "A bento-grid style card layout with images, titles, and CTAs for showcasing portfolio items or features.",
	"keywords": [ "bento", "cards", "grid", "portfolio", "gallery", "showcase" ],
	"textdomain": "swishfolio-core",
	"attributes": {
		"gridGap": {
			"type": "string",
			"default": "1.5rem"
		},
		"cardStyle": {
			"type": "string",
			"default": "overlay"
		},
		"cardOverlayColor": {
			"type": "string",
			"default": ""
		},
		"cardOverlayOpacity": {
			"type": "number",
			"default": 60
		},
		"accentColor": {
			"type": "string",
			"default": ""
		},
		"cardSubtitleColor": {
			"type": "string",
			"default": ""
		},
		"cardTitleColor": {
			"type": "string",
			"default": ""
		},
		"cardDescriptionColor": {
			"type": "string",
			"default": ""
		},
		"cardTextBg": {
			"type": "string",
			"default": ""
		},
		"cardTitleFontSize": {
			"type": "string",
			"default": ""
		},
		"layeredImages": {
			"type": "boolean",
			"default": false
		},
		"layeredBgColor": {
			"type": "string",
			"default": ""
		},
		"layeredPaddingTop": {
			"type": "number",
			"default": 10
		},
		"ctaType": {
			"type": "string",
			"default": "none"
		},
		"ctaText": {
			"type": "string",
			"default": "View All"
		},
		"ctaUrl": {
			"type": "string",
			"default": ""
		},
		"ctaTextColor": {
			"type": "string",
			"default": ""
		},
		"ctaBgColor": {
			"type": "string",
			"default": ""
		}
	},
	"supports": {
		"align": [ "wide", "full" ],
		"html": false,
		"color": {
			"background": true,
			"text": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true
		}
	},
	"editorScript": "file:./build/index.js",
	"editorStyle": "file:./build/index.css",
	"style": "file:./build/style-index.css"
}
